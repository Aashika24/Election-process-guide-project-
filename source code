<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Election Process Guide</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
 
        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
 
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
        }
 
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
 
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
 
        @keyframes confetti {
            0% { transform: translateY(0) rotate(0deg); opacity: 1; }
            100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
        }
 
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
        /* Removed heavy gradient animation for performance */
            min-height: 100vh;
            padding: 20px;
            position: relative;
            overflow-x: hidden;
        }
 
        /* Fun floating background shapes */
        body::before,
        body::after {
            content: '';
            position: fixed;
            border-radius: 50%;
            opacity: 0.1;
            z-index: 0;
            animation: float 6s ease-in-out infinite;
        }
 
        body::before {
            width: 300px;
            height: 300px;
            background: white;
            top: 10%;
            left: -150px;
        }
 
        body::after {
            width: 400px;
            height: 400px;
            background: white;
            bottom: 10%;
            right: -200px;
            animation-delay: 3s;
        }
 
        .container {
            max-width: 1100px;
            width: 95%;
            margin: 0 auto;
            background: white;
            border-radius: 30px;
            box-shadow: 0 30px 90px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(255, 255, 255, 0.1);
            overflow: hidden;
            position: relative;
            z-index: 1;
            transform: translateY(0);
            transition: transform 0.3s ease;
        }
 
        .container:hover {
            transform: translateY(-5px);
            box-shadow: 0 35px 100px rgba(0, 0, 0, 0.35);
        }
 
        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
            background-size: 200% 200%;
            animation: gradientShift 10s ease infinite;
            color: white;
            padding: 50px 30px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
 
        .header::before {
            content: '⭐';
            position: absolute;
            font-size: 3em;
            top: 20px;
            left: 20px;
            animation: pulse 2s ease-in-out infinite;
        }
 
        .header::after {
            content: '🎉';
            position: absolute;
            font-size: 3em;
            top: 20px;
            right: 20px;
            animation: pulse 2s ease-in-out infinite;
            animation-delay: 1s;
        }
 
        .header h1 {
            font-size: 2.8em;
            margin-bottom: 15px;
            animation: bounce 2s ease-in-out infinite;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
        }
 
        .header p {
            font-size: 1.2em;
            opacity: 0.95;
            animation: fadeIn 1s ease;
        }
 
        .tabs {
            display: flex;
            background: linear-gradient(to right, #f8f9fa, #e9ecef);
            border-bottom: 3px solid transparent;
            position: relative;
        }
 
        .tabs::after {
            content: '';
            position: absolute;
            bottom: -3px;
            left: 0;
            width: 25%;
            height: 3px;
            background: linear-gradient(90deg, #667eea, #f093fb);
            transition: left 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }
 
        .tab {
            flex: 1;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            background: transparent;
            border: none;
            font-size: 1.1em;
            font-weight: 700;
            color: #6c757d;
            transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            position: relative;
        }

        .tab:focus-visible {
            outline: 3px solid #667eea;
            outline-offset: 2px;
            border-radius: 8px;
        }
 
        .tab:hover {
            color: #667eea;
            transform: translateY(-3px) scale(1.05);
        }
 
        .tab.active {
            color: #667eea;
            transform: scale(1.1);
        }
 
        .tab:nth-child(1).active ~ .tabs::after { left: 0%; }
        .tab:nth-child(2).active ~ .tabs::after { left: 25%; }
        .tab:nth-child(3).active ~ .tabs::after { left: 50%; }
        .tab:nth-child(4).active ~ .tabs::after { left: 75%; }
 
        .content {
            padding: 30px;
        }
 
        .tab-content {
            display: none;
        }
 
        .tab-content.active {
            display: block;
            animation: fadeIn 0.4s ease;
        }
 
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
 
        .timeline {
            position: relative;
            padding: 20px 0;
        }
 
        .timeline::before {
            content: '';
            position: absolute;
            left: 30px;
            top: 0;
            bottom: 0;
            width: 4px;
            background: linear-gradient(to bottom, #667eea, #764ba2, #f093fb);
            border-radius: 2px;
            box-shadow: 0 0 10px rgba(102, 126, 234, 0.5);
        }
 
        .timeline-item {
            position: relative;
            padding-left: 70px;
            margin-bottom: 40px;
            cursor: pointer;
            transition: all 0.3s ease;
        }
 
        .timeline-item:hover {
            transform: translateX(10px);
        }
 
        .timeline-item:hover .timeline-dot {
            transform: scale(1.4) rotate(180deg);
            box-shadow: 0 0 20px rgba(102, 126, 234, 0.8);
        }
 
        .timeline-item:hover .timeline-content {
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.2);
        }
 
        .timeline-dot {
            position: absolute;
            left: 20px;
            top: 5px;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: white;
            border: 5px solid #667eea;
            transition: all 0.3s ease;
            z-index: 1;
            will-change: transform;
            transform: translateZ(0);
            backface-visibility: hidden;
            box-shadow: 0 0 0 0 rgba(102, 126, 234, 0.4);
            animation: pulse-ring 2s infinite paused;
        }
 
        @keyframes pulse-ring {
            0% { box-shadow: 0 0 0 0 rgba(102, 126, 234, 0.4); }
            50% { box-shadow: 0 0 0 10px rgba(102, 126, 234, 0); }
            100% { box-shadow: 0 0 0 0 rgba(102, 126, 234, 0); }
        }
 
        .timeline-item.completed .timeline-dot {
            background: linear-gradient(135deg, #667eea, #764ba2);
            animation: completed-spin 0.6s ease;
        }
 
        @keyframes completed-spin {
            from { transform: rotate(0deg) scale(1); }
            to { transform: rotate(360deg) scale(1); }
        }
 
        .timeline-content {
            background: linear-gradient(135deg, #f8f9fa 0%, #fff 100%);
            padding: 25px;
            border-radius: 15px;
            border-left: 5px solid #667eea;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }
 
        .timeline-content:hover {
            border-left-color: #f093fb;
        }
 
        .timeline-content h3 {
            background: linear-gradient(135deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 10px;
            font-size: 1.4em;
        }
 
        .timeline-content .date {
            color: #6c757d;
            font-size: 0.95em;
            margin-bottom: 12px;
            font-weight: 700;
            display: inline-block;
            background: #e9ecef;
            padding: 5px 12px;
            border-radius: 20px;
        }
 
        .timeline-content p {
            color: #495057;
            line-height: 1.6;
        }
 
        .timeline-content .details {
            display: none;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #dee2e6;
        }
 
        .timeline-content .details.show {
            display: block;
        }
 
        .timeline-content ul {
            margin-left: 20px;
            margin-top: 10px;
        }
 
        .timeline-content li {
            margin-bottom: 8px;
            color: #495057;
        }
 
        .step-card {
            background: linear-gradient(135deg, #fff 0%, #f8f9fa 100%);
            padding: 30px;
            border-radius: 20px;
            margin-bottom: 25px;
            border-left: 6px solid #667eea;
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
            position: relative;
            overflow: hidden;
        }
 
        .step-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(240, 147, 251, 0.05));
            opacity: 0;
            transition: opacity 0.3s ease;
        }
 
        .step-card:hover::before {
            opacity: 1;
        }
 
        .step-card:hover {
            transform: translateX(10px) scale(1.02);
            box-shadow: 0 15px 40px rgba(102, 126, 234, 0.2);
            border-left-color: #f093fb;
        }
 
        .step-card:nth-child(odd) {
            border-left-color: #764ba2;
        }
 
        .step-card:nth-child(3n) {
            border-left-color: #f093fb;
        }
 
        .step-number {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border-radius: 50%;
            font-weight: bold;
            font-size: 1.4em;
            margin-right: 20px;
            float: left;
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
            transition: all 0.3s ease;
            animation: pulse 2s ease-in-out infinite;
        }
 
        .step-card:hover .step-number {
            transform: rotate(360deg) scale(1.1);
            animation: none;
        }
 
        .step-card h3 {
            color: #212529;
            margin-bottom: 10px;
            font-size: 1.3em;
        }
 
        .step-card p {
            color: #495057;
            line-height: 1.7;
        }
 
        .quiz-container {
            background: linear-gradient(135deg, #f8f9fa 0%, #fff 100%);
            padding: 35px;
            border-radius: 20px;
            margin-bottom: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            border: 3px solid transparent;
            background-clip: padding-box;
            position: relative;
        }
 
        .quiz-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border-radius: 20px;
            padding: 3px;
            background: linear-gradient(135deg, #667eea, #764ba2, #f093fb);
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
        }
 
        .question {
            font-size: 1.3em;
            color: #212529;
            margin-bottom: 25px;
            font-weight: 700;
            text-align: center;
            padding: 15px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
 
        .quiz-option {
            background: linear-gradient(135deg, #fff 0%, #f8f9fa 100%);
            padding: 18px 25px;
            margin-bottom: 15px;
            border-radius: 15px;
            cursor: pointer;
            border: 3px solid #e9ecef;
            transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            position: relative;
            overflow: hidden;
            font-weight: 600;
        }
 
        .quiz-option::before {
            content: '';
            position: absolute;
            left: -100%;
            top: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(102, 126, 234, 0.1), transparent);
            transition: left 0.5s ease;
        }
 
        .quiz-option:hover::before {
            left: 100%;
        }
 
        .quiz-option:hover {
            border-color: #667eea;
            transform: translateX(10px) scale(1.02);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.2);
        }
 
        .quiz-option.selected {
            border-color: #667eea;
            background: linear-gradient(135deg, #f0f2ff, #fff);
            transform: scale(1.02);
        }
 
        .quiz-option.correct {
            border-color: #28a745;
            background: linear-gradient(135deg, #d4edda, #fff);
            animation: celebrate 0.6s ease;
        }
 
        .quiz-option.correct::after {
            content: '✓';
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.5em;
            color: #28a745;
            font-weight: bold;
        }
 
        @keyframes celebrate {
            0%, 100% { transform: scale(1); }
            25% { transform: scale(1.05) rotate(-2deg); }
            75% { transform: scale(1.05) rotate(2deg); }
        }
 
        .quiz-option.incorrect {
            border-color: #dc3545;
            background: linear-gradient(135deg, #f8d7da, #fff);
            animation: shake 0.5s ease;
        }
 
        .quiz-option.incorrect::after {
            content: '✗';
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.5em;
            color: #dc3545;
            font-weight: bold;
        }
 
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }
 
        .quiz-feedback {
            margin-top: 20px;
            padding: 15px;
            border-radius: 10px;
            display: none;
        }
 
        .quiz-feedback.show {
            display: block;
        }
 
        .quiz-feedback.correct {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }
 
        .quiz-feedback.incorrect {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }
 
        .btn {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            padding: 15px 40px;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            font-size: 1.1em;
            font-weight: 700;
            transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            margin-top: 20px;
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
            position: relative;
            overflow: hidden;
        }
 
        .btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }
 
        .btn:hover::before {
            width: 300px;
            height: 300px;
        }
 
        .btn:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 15px 35px rgba(102, 126, 234, 0.6);
        }
 
        .btn:active {
            transform: translateY(-2px) scale(1.02);
        }
 
        .checklist {
            list-style: none;
        }
 
        .checklist li {
            padding: 20px;
            background: linear-gradient(135deg,#fff 0%,#f8f9fa 100%);
            margin-bottom:12px;
            border-radius:15px;
            cursor:pointer;
            transition:all 0.3s cubic-bezier(0.68,-0.55,0.265,1.55);
            border-left:5px solid #e9ecef;
            box-shadow:0 3px 10px rgba(0,0,0,0.05);
            font-weight:600;
        }
        .checklist li:hover {
            transform:translateX(15px) scale(1.02);
            border-left-color:#667eea;
            box-shadow:0 8px 25px rgba(102,126,234,0.15);
        }
        .checklist li:focus-visible {
            outline:3px solid #667eea;
            outline-offset:2px;
        }
 
        .checklist li.checked {
            background: linear-gradient(135deg, #d4edda 0%, #a8e6cf 100%);
            border-left-color: #28a745;
            animation: checkBounce 0.5s ease;
        }
 
        @keyframes checkBounce {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
 
        .checklist li::before {
            content: '☐';
            margin-right: 15px;
            font-size: 1.5em;
            color: #6c757d;
            transition: all 0.3s ease;
            display: inline-block;
        }
 
        .checklist li:hover::before {
            transform: scale(1.2) rotate(10deg);
        }
 
        .checklist li.checked::before {
            content: '✅';
            animation: spin 0.5s ease;
        }
 
        @keyframes spin {
            from { transform: rotate(0deg) scale(0); }
            to { transform: rotate(360deg) scale(1); }
        }
 
        .info-box {
            background: linear-gradient(135deg, #fff3cd 0%, #fff9e6 100%);
            border: 2px solid #ffc107;
            border-left: 6px solid #ffc107;
            padding: 25px;
            border-radius: 15px;
            margin: 25px 0;
            box-shadow: 0 5px 20px rgba(255, 193, 7, 0.2);
            transition: all 0.3s ease;
        }
 
        .info-box:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(255, 193, 7, 0.3);
        }
 
        .info-box h4 {
            color: #856404;
            margin-bottom: 12px;
            font-size: 1.2em;
        }
 
        .info-box p {
            color: #856404;
            margin: 0;
            line-height: 1.6;
        }
 
        .progress-bar {
            height: 35px;
            background: linear-gradient(135deg, #e9ecef 0%, #f8f9fa 100%);
            border-radius: 25px;
            overflow: hidden;
            margin: 25px 0;
            box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.1);
            border: 2px solid #dee2e6;
        }
 
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #667eea, #764ba2, #f093fb);
            background-size: 200% 100%;
            animation: shimmer 2s infinite;
            width: 0%;
            transition: width 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 1.1em;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
        }
 
        @keyframes shimmer {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
 
@media (max-width: 768px) {
            .header h1 {
                font-size: 1.8em;
            }

            .tabs {
                flex-direction: column;
            }

            .tab {
                padding: 20px 15px;
                min-height: 60px; /* Better touch target */
                font-size: 1.1em;
            }

            .content {
                padding: 20px 15px;
            }

            .step-number {
                float: none;
                display: block;
                margin-bottom: 10px;
            }

            /* Fix timeline on mobile */
            .timeline::before {
                left: 15px;
                width: 3px;
            }

            .timeline-dot {
                left: 5px;
                width: 20px;
                height: 20px;
                border-width: 4px;
            }

            .timeline-item {
                padding-left: 55px;
                margin-bottom: 30px;
            }
        }

        /* Extra small screens */
        @media (max-width: 480px) {
            .timeline::before {
                left: 12px;
            }

            .timeline-dot {
                left: 2px;
                width: 18px;
                height: 18px;
            }

            .timeline-item {
                padding-left: 50px;
            }

            .container {
                margin: 10px;
                border-radius: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🗳️ Election Process Guide</h1>
            <p>Your interactive guide to understanding elections</p>
        </div>
 
        <div class="tabs" role="tablist" aria-label="Election guide tabs">
            <button class="tab active" role="tab" aria-selected="true" aria-controls="timeline" tabindex="0" onclick="showTab('timeline')" onkeydown="handleTabKey(event, this)">📅 Timeline</button>
            <button class="tab" role="tab" aria-selected="false" aria-controls="steps" tabindex="-1" onclick="showTab('steps')" onkeydown="handleTabKey(event, this)">📝 How to Vote</button>
            <button class="tab" role="tab" aria-selected="false" aria-controls="quiz" tabindex="-1" onclick="showTab('quiz')" onkeydown="handleTabKey(event, this)">🎯 Test Your Knowledge</button>
            <button class="tab" role="tab" aria-selected="false" aria-controls="checklist" tabindex="-1" onclick="showTab('checklist')" onkeydown="handleTabKey(event, this)">✅ Voter Checklist</button>
        </div>
 
        <div class="content">
            <!-- Timeline Tab -->
            <div id="timeline" class="tab-content active">
                <h2 style="margin-bottom: 30px; color: #212529;">Election Timeline</h2>
                <div class="timeline">
                    <div class="timeline-item" onclick="toggleDetails(this)">
                        <div class="timeline-dot"></div>
                        <div class="timeline-content">
                            <h3>Voter Registration</h3>
                            <div class="date">Ongoing - Deadlines vary by state</div>
                            <p>Register to vote or update your registration information.</p>
                            <div class="details">
                                <ul>
                                    <li>Check if you're already registered</li>
                                    <li>Register online, by mail, or in person</li>
                                    <li>Registration deadlines are typically 15-30 days before election</li>
                                    <li>Some states offer same-day registration</li>
                                    <li>Update your address if you've moved</li>
                                </ul>
                            </div>
                        </div>
                    </div>
 
                    <div class="timeline-item" onclick="toggleDetails(this)">
                        <div class="timeline-dot"></div>
                        <div class="timeline-content">
                            <h3>Candidate Filing Period</h3>
                            <div class="date">Months before primary elections</div>
                            <p>Candidates declare their intention to run for office.</p>
                            <div class="details">
                                <ul>
                                    <li>Candidates file paperwork with election officials</li>
                                    <li>Must meet eligibility requirements</li>
                                    <li>Pay filing fees or collect signatures</li>
                                    <li>Declare party affiliation (if applicable)</li>
                                </ul>
                            </div>
                        </div>
                    </div>
 
                    <div class="timeline-item" onclick="toggleDetails(this)">
                        <div class="timeline-dot"></div>
                        <div class="timeline-content">
                            <h3>Primary Elections</h3>
                            <div class="date">Spring/Summer of election year</div>
                            <p>Party members select their nominees for the general election.</p>
                            <div class="details">
                                <ul>
                                    <li>Open primaries: any registered voter can participate</li>
                                    <li>Closed primaries: only party members can vote</li>
                                    <li>Presidential primaries determine delegates</li>
                                    <li>State and local races narrow down candidates</li>
