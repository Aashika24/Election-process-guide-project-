            <!-- How to Vote Tab -->
            <div id="steps" class="tab-content">
                <h2 style="margin-bottom: 30px; color: #212529;">Step-by-Step Voting Guide</h2>
                
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h3>Check Your Registration</h3>
                    <p>Verify you're registered to vote at your current address. Visit your state's election website or use the national voter registration verification tool. If you're not registered or need to update your information, do so before the deadline.</p>
                </div>
 
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h3>Research Candidates & Issues</h3>
                    <p>Learn about the candidates running for office and any ballot measures. Read voter guides, watch debates, and review candidate websites. Consider their positions on issues that matter to you.</p>
                </div>
 
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h3>Choose Your Voting Method</h3>
                    <p>Decide whether to vote early in person, by mail/absentee ballot, or on Election Day. Each method has different deadlines and requirements. Choose what works best for your schedule.</p>
                </div>
 
                <div class="step-card">
                    <div class="step-number">4</div>
                    <h3>Prepare Required Documents</h3>
                    <p>Check what ID or documentation you need to bring. Requirements vary by state and voting method. Common IDs include driver's license, passport, or state ID card.</p>
                </div>
 
                <div class="step-card">
                    <div class="step-number">5</div>
                    <h3>Find Your Polling Location</h3>
                    <p>Locate your assigned polling place if voting in person. This may change from previous elections, so verify the location. Check polling hours and plan your visit to avoid peak times.</p>
                </div>
 
                <div class="step-card">
                    <div class="step-number">6</div>
                    <h3>Cast Your Ballot</h3>
                    <p>Follow instructions carefully when marking your ballot. Take your time and review your choices before submitting. If you make a mistake, ask for a new ballot. Don't hesitate to ask poll workers for assistance.</p>
                </div>
 
                <div class="step-card">
                    <div class="step-number">7</div>
                    <h3>Verify Your Vote Was Counted</h3>
                    <p>If you voted by mail, track your ballot online. Many states offer ballot tracking systems. Keep your "I Voted" sticker or receipt as proof of voting. Follow up if you notice any issues.</p>
                </div>
 
                <div class="info-box">
                    <h4>💡 Important Reminder</h4>
                    <p>Your vote is private. You are never required to tell anyone who you voted for. If you experience any problems or intimidation at the polls, contact your local election office immediately.</p>
                </div>
            </div>
 
            <!-- Quiz Tab -->
            <div id="quiz" class="tab-content">
                <h2 style="margin-bottom: 30px; color: #212529;">Test Your Election Knowledge</h2>
                <div id="quizProgress" class="progress-bar">
                    <div class="progress-fill">0% Complete</div>
                </div>
                <div id="quizArea"></div>
            </div>
 
            <!-- Checklist Tab -->
            <div id="checklist" class="tab-content">
                <h2 style="margin-bottom: 30px; color: #212529;">Voter Readiness Checklist</h2>
                <p style="margin-bottom: 20px; color: #6c757d;">Click each item as you complete it to track your progress.</p>
                
                <div id="checklistProgress" class="progress-bar">
                    <div class="progress-fill">0% Complete</div>
                </div>
 
        <ul class="checklist" role="list">
                    <li role="checkbox" aria-checked="false" tabindex="0" onclick="toggleCheck(this)" onkeydown="handleCheckKey(event, this)">Check my voter registration status</li>
                    <li role="checkbox" aria-checked="false" tabindex="0" onclick="toggleCheck(this)" onkeydown="handleCheckKey(event, this)">Update my registration if I moved</li>
                    <li role="checkbox" aria-checked="false" tabindex="0" onclick="toggleCheck(this)" onkeydown="handleCheckKey(event, this)">Research all candidates on my ballot</li>
                    <li role="checkbox" aria-checked="false" tabindex="0" onclick="toggleCheck(this)" onkeydown="handleCheckKey(event, this)">Review ballot measures and propositions</li>
                    <li role="checkbox" aria-checked="false" tabindex="0" onclick="toggleCheck(this)" onkeydown="handleCheckKey(event, this)">Decide on my voting method (in-person, early, or mail)</li>
                    <li role="checkbox" aria-checked="false" tabindex="0" onclick="toggleCheck(this)" onkeydown="handleCheckKey(event, this)">Request absentee/mail ballot (if applicable)</li>
                    <li role="checkbox" aria-checked="false" tabindex="0" onclick="toggleCheck(this)" onkeydown="handleCheckKey(event, this)">Find my polling location</li>
                    <li role="checkbox" aria-checked="false" tabindex="0" onclick="toggleCheck(this)" onkeydown="handleCheckKey(event, this)">Check what ID I need to bring</li>
                    <li role="checkbox" aria-checked="false" tabindex="0" onclick="toggleCheck(this)" onkeydown="handleCheckKey(event, this)">Plan my schedule for Election Day or early voting</li>
                    <li role="checkbox" aria-checked="false" tabindex="0" onclick="toggleCheck(this)" onkeydown="handleCheckKey(event, this)">Review sample ballot online</li>
                    <li role="checkbox" aria-checked="false" tabindex="0" onclick="toggleCheck(this)" onkeydown="handleCheckKey(event, this)">Make note of polling hours</li>
                    <li role="checkbox" aria-checked="false" tabindex="0" onclick="toggleCheck(this)" onkeydown="handleCheckKey(event, this)">Tell friends and family about voting</li>
                </ul>
            </div>
        </div>
    </div>
 
    <script>
        // Quiz questions
        const quizQuestions = [
            {
                question: "When is Election Day for federal elections in the United States?",
                options: [
                    "First Tuesday in November",
                    "First Tuesday after the first Monday in November",
                    "Second Tuesday in November",
                    "Last Tuesday in October"
                ],
                correct: 1,
                explanation: "Election Day is the first Tuesday after the first Monday in November. This ensures Election Day falls between November 2 and November 8."
            },
            {
                question: "What should you bring with you when voting in person?",
                options: [
                    "Nothing is required",
                    "Proof of residency",
                    "Valid ID (requirements vary by state)",
                    "Voter registration card"
                ],
                correct: 2,
                explanation: "Most states require some form of valid identification, though specific requirements vary. Check your state's rules before heading to the polls."
            },
            {
                question: "Can you still vote if you're in line when polls close?",
                options: [
                    "No, you must be inside the polling place",
                    "Yes, as long as you were in line when polls closed",
                    "Only if you have an emergency",
                    "It depends on the state"
                ],
                correct: 1,
                explanation: "Yes! If you're in line when the polls close, you have the right to vote. Stay in line until you can cast your ballot."
            },
            {
                question: "What happens during primary elections?",
                options: [
                    "The president is elected",
                    "Citizens vote on ballot measures only",
                    "Political parties select their nominees for the general election",
                    "Local officials are elected"
                ],
                correct: 2,
                explanation: "Primary elections are when political parties choose their candidates who will run in the general election. Voters help decide which candidates will represent each party."
            },
            {
                question: "How can you verify your ballot was counted if you voted by mail?",
                options: [
                    "You cannot verify mail ballots",
                    "Wait for election results",
                    "Use your state's ballot tracking system",
                    "Call your county election office"
                ],
                correct: 2,
                explanation: "Most states offer online ballot tracking systems where you can check the status of your mail-in ballot from when it's sent to when it's counted."
            }
        ];
 
        let currentQuestion = 0;
        let correctAnswers = 0;
 
        function showTab(tabName) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.remove('active');
            });
            
            // Remove active from all tab buttons
            document.querySelectorAll('.tab').forEach((tab, index) => {
                tab.classList.remove('active');
                tab.setAttribute('aria-selected', 'false');
                tab.tabIndex = -1;
            });
            
            // Show selected tab
            const targetTab = document.getElementById(tabName);
            targetTab.classList.add('active');
            
            const activeButton = event ? event.target.closest('.tab') : document.querySelector('.tab[aria-controls="' + tabName + '"]');
            if (activeButton) {
                activeButton.classList.add('active');
                activeButton.setAttribute('aria-selected', 'true');
                activeButton.tabIndex = 0;
                activeButton.focus();
            }

            // Initialize quiz if quiz tab is selected
            if (tabName === 'quiz' && currentQuestion === 0) {
                loadQuestion();
            }
        }

        function handleTabKey(event, button) {
            const tabs = Array.from(document.querySelectorAll('.tab'));
            const currentIndex = tabs.indexOf(button);
            
            if (event.key === 'ArrowRight') {
                event.preventDefault();
                const nextIndex = (currentIndex + 1) % tabs.length;
                tabs[nextIndex].focus();
                showTab(tabs[nextIndex].getAttribute('aria-controls'));
            } else if (event.key === 'ArrowLeft') {
                event.preventDefault();
                const prevIndex = currentIndex === 0 ? tabs.length - 1 : currentIndex - 1;
                tabs[prevIndex].focus();
                showTab(tabs[prevIndex].getAttribute('aria-controls'));
            } else if (event.key === 'Enter' || event.key === ' ') {
                event.preventDefault();
                showTab(button.getAttribute('aria-controls'));
            }
        }
 
        function toggleDetails(element) {
            const details = element.querySelector('.details');
            const dot = element.querySelector('.timeline-dot');
            
            // Close all other details
            document.querySelectorAll('.timeline-item .details').forEach(detail => {
                if (detail !== details) {
                    detail.classList.remove('show');
                }
            });
            
            details.classList.toggle('show');
            
            // Mark as completed when expanded
            if (details.classList.contains('show')) {
                element.classList.add('completed');
            }
        }
 
        function toggleCheck(element) {
            element.classList.toggle('checked');
            const isChecked = element.classList.contains('checked');
            element.setAttribute('aria-checked', isChecked ? 'true' : 'false');
            updateChecklistProgress();
        }

        function handleCheckKey(event, element) {
            if (event.key === 'Enter' || event.key === ' ') {
                event.preventDefault();
                toggleCheck(element);
            } else if (event.key === 'Tab') {
                // Allow normal tab navigation
            }
        }
 
        function updateChecklistProgress() {
            const total = document.querySelectorAll('.checklist li').length;
            const checked = document.querySelectorAll('.checklist li.checked').length;
            const percentage = Math.round((checked / total) * 100);
            
            const progressBar = document.querySelector('#checklistProgress .progress-fill');
            progressBar.style.width = percentage + '%';
            progressBar.textContent = percentage + '% Complete';
        }
 
        function loadQuestion() {
            if (currentQuestion >= quizQuestions.length) {
                showQuizResults();
                return;
            }
 
            const q = quizQuestions[currentQuestion];
            const quizArea = document.getElementById('quizArea');
            
            let html = `
                <div class="quiz-container">
                    <div class="question">Question ${currentQuestion + 1} of ${quizQuestions.length}: ${q.question}</div>
            `;
            
            q.options.forEach((option, index) => {
                html += `
                    <div class="quiz-option" onclick="selectAnswer(${index})">
                        ${option}
                    </div>
                `;
            });
            
            html += `
                    <div id="feedback" class="quiz-feedback"></div>
                </div>
            `;
            
            quizArea.innerHTML = html;
        }
 
        function selectAnswer(selectedIndex) {
            const q = quizQuestions[currentQuestion];
            const options = document.querySelectorAll('.quiz-option');
            const feedback = document.getElementById('feedback');
            
            // Disable all options
            options.forEach((option, index) => {
                option.onclick = null;
                option.style.pointerEvents = 'none';
                if (index === q.correct) {
                    setTimeout(() => option.classList.add('correct'), 200);
                } else if (index === selectedIndex) {
                    option.classList.add('incorrect');
                }
            });
            
            // Show feedback with animation
            if (selectedIndex === q.correct) {
                correctAnswers++;
                feedback.className = 'quiz-feedback show correct';
                feedback.innerHTML = `
                    <div style="font-size: 2em; margin-bottom: 10px; animation: bounce 0.5s ease;">✓</div>
                    <strong style="font-size: 1.3em;">Correct!</strong><br>
                    <p style="margin-top: 10px;">${q.explanation}</p>
                    <button class="btn" onclick="nextQuestion()">Next Question →</button>
                `;
                // Add sparkle effect for correct answer
                createSparkles(options[selectedIndex]);
            } else {
                feedback.className = 'quiz-feedback show incorrect';
                feedback.innerHTML = `
                    <div style="font-size: 2em; margin-bottom: 10px; animation: shake 0.5s ease;">✗</div>
                    <strong style="font-size: 1.3em;">Not quite!</strong><br>
                    <p style="margin-top: 10px;">${q.explanation}</p>
                    <button class="btn" onclick="nextQuestion()">Next Question →</button>
                `;
            }
            
            updateQuizProgress();
        }
 
        function createSparkles(element) {
            const rect = element.getBoundingClientRect();
        const sparkleCount = 5; // Reduced from 10 for performance
            
            for (let i = 0; i < sparkleCount; i++) {
                const sparkle = document.createElement('div');
                sparkle.textContent = '✨';
                sparkle.style.position = 'fixed';
                sparkle.style.left = rect.left + rect.width / 2 + 'px';
                sparkle.style.top = rect.top + rect.height / 2 + 'px';
                sparkle.style.fontSize = '20px';
                sparkle.style.pointerEvents = 'none';
                sparkle.style.zIndex = '9999';
                
                const angle = (Math.PI * 2 * i) / sparkleCount;
                const velocity = 50;
                const vx = Math.cos(angle) * velocity;
                const vy = Math.sin(angle) * velocity;
                
                sparkle.style.animation = 'sparkle 1s ease-out forwards';
                sparkle.style.setProperty('--vx', vx + 'px');
                sparkle.style.setProperty('--vy', vy + 'px');
                
                document.body.appendChild(sparkle);
                setTimeout(() => sparkle.remove(), 1000);
            }
            
            // Add sparkle animation to stylesheet
            if (!document.getElementById('sparkle-style')) {
                const style = document.createElement('style');
                style.id = 'sparkle-style';
                style.textContent = `
                    @keyframes sparkle {
                        0% { transform: translate(0, 0) scale(0); opacity: 1; }
                        100% { transform: translate(var(--vx), var(--vy)) scale(1); opacity: 0; }
                    }
                `;
                document.head.appendChild(style);
            }
        }
 
        function nextQuestion() {
            currentQuestion++;
            loadQuestion();
        }
 
        function updateQuizProgress() {
            const percentage = Math.round(((currentQuestion + 1) / quizQuestions.length) * 100);
            const progressBar = document.querySelector('#quizProgress .progress-fill');
            progressBar.style.width = percentage + '%';
            progressBar.textContent = percentage + '% Complete';
        }
 
        function showQuizResults() {
            const percentage = Math.round((correctAnswers / quizQuestions.length) * 100);
            const quizArea = document.getElementById('quizArea');
            
            let message = '';
            let emoji = '';
            
            if (percentage === 100) {
                message = "Perfect score! You're an election expert!";
                emoji = "🏆";
                createConfetti();
            } else if (percentage >= 80) {
                message = "Great job! You know your stuff!";
                emoji = "🌟";
            } else if (percentage >= 60) {
                message = "Good effort! Keep learning!";
                emoji = "👍";
            } else {
                message = "Keep studying! Review the timeline and steps.";
                emoji = "📚";
            }
            
            quizArea.innerHTML = `
                <div class="quiz-container" style="text-align: center;">
                    <div style="font-size: 5em; margin-bottom: 20px; animation: bounce 1s ease-in-out infinite;">${emoji}</div>
                    <h2 style="background: linear-gradient(135deg, #667eea, #764ba2); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 20px; font-size: 2em;">Quiz Complete!</h2>
                    <p style="font-size: 1.4em; margin-bottom: 15px; font-weight: 600;">
                        You got ${correctAnswers} out of ${quizQuestions.length} correct
                    </p>
                    <div style="font-size: 3em; font-weight: bold; background: linear-gradient(135deg, #667eea, #764ba2); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 20px; animation: pulse 1.5s ease-in-out infinite;">
                        ${percentage}%
                    </div>
                    <p style="margin-bottom: 30px; font-size: 1.2em; color: #495057;">${message}</p>
                    <button class="btn" onclick="restartQuiz()">🔄 Try Again</button>
                </div>
            `;
        }
 
        function createConfetti() {
            const colors = ['#667eea', '#764ba2', '#f093fb', '#ffc107', '#28a745'];
        const confettiCount = 20; // Reduced from 50 for performance
            
            for (let i = 0; i < confettiCount; i++) {
                const confetti = document.createElement('div');
                confetti.style.position = 'fixed';
                confetti.style.width = '10px';
                confetti.style.height = '10px';
                confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                confetti.style.left = Math.random() * 100 + '%';
                confetti.style.top = '-10px';
                confetti.style.borderRadius = Math.random() > 0.5 ? '50%' : '0';
                confetti.style.opacity = '1';
                confetti.style.zIndex = '9999';
                confetti.style.animation = `confetti ${2 + Math.random() * 2}s ease-out forwards`;
                confetti.style.animationDelay = Math.random() * 0.5 + 's';
                
                document.body.appendChild(confetti);
                
                setTimeout(() => confetti.remove(), 4000);
            }
        }
 
        function restartQuiz() {
            currentQuestion = 0;
            correctAnswers = 0;
            const progressBar = document.querySelector('#quizProgress .progress-fill');
            progressBar.style.width = '0%';
            progressBar.textContent = '0% Complete';
            loadQuestion();
        }
    </script>
